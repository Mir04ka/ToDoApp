{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ToDoAppDb;Username=postgres;Password=SuperSecretPassword12345"
  },
  "JwtConfig": {
    "SigningKey": "SigningPrivateKeyForJwtServices12345!",
    "EncryptionKey": "MySuperSecretEncryptionKey123456"
  },
  "AuthMicroserviceUrl": "http://localhost:5001",

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/todoapp-.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
